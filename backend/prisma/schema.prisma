// prisma/schema.prisma - Complete working schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ============ ENUMS ============

enum UserRole {
  PATIENT
  DOCTOR
  ADMIN
}

// ============ USER MODEL ============

model User {
  id                String           @id @default(cuid())
  name              String
  email             String           @unique
  password          String
  role              UserRole         @default(PATIENT)
  latitude          Float?
  longitude         Float?
  refreshToken      String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  
  // Relations
  appointments      Appointment[]
  symptoms          Symptom[]
  symptomCheckers   SymptomChecker[]
  diagnoses         Diagnosis[]
  symptomSessions   SymptomSession[]

  @@map("users")
}

// ============ SYMPTOM MODELS ============

model Symptom {
  id                        String                      @id @default(cuid())
  name                      String                      @unique
  description               String?
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @updatedAt
  
  // Relations
  symptoms                  Symptom[]                   @relation("UserSymptoms")
  relatedTo                 Symptom?                    @relation("UserSymptoms", fields: [relatedToId], references: [id])
  relatedToId               String?
  userFromId                User?                       @relation(fields: [userId], references: [id])
  userId                    String?
  symptomConditionRelations SymptomConditionRelation[]

  @@index([name])
  @@map("symptoms")
}

model MedicalCondition {
  id                        String                      @id @default(cuid())
  name                      String                      @unique
  description               String?
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @updatedAt
  
  // Relations
  symptomConditionRelations SymptomConditionRelation[]
  specializationConditions  SpecializationCondition[]

  @@index([name])
  @@map("medical_conditions")
}

model SymptomConditionRelation {
  id           String           @id @default(cuid())
  symptomId    String
  conditionId  String
  probability  Float            @default(0.5)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  
  // Relations
  symptom      Symptom          @relation(fields: [symptomId], references: [id], onDelete: Cascade)
  condition    MedicalCondition @relation(fields: [conditionId], references: [id], onDelete: Cascade)

  @@unique([symptomId, conditionId])
  @@index([symptomId])
  @@index([conditionId])
  @@map("symptom_condition_relations")
}

model SymptomSession {
  id                 String              @id @default(cuid())
  userId             String
  symptoms           String[]
  age                Int
  gender             String
  duration           String?
  severity           String?
  predictedDisease   Json                // Array of {condition, probability}
  urgencyLevel       String
  aiExplanation      String              @db.Text
  recommendedDoctor  String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  
  // Relations
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendedDoctors RecommendedDoctor[]

  @@index([userId])
  @@index([createdAt])
  @@map("symptom_sessions")
}

// ============ DOCTOR MODELS ============

model Doctor {
  id                    String                    @id @default(cuid())
  firstName             String
  lastName              String
  email                 String                    @unique
  phone                 String
  password              String
  qualifications        String
  licenseNumber         String                    @unique
  yearsOfExperience     Int
  clinicName            String?
  clinicAddress         String?
  clinicCity            String?
  clinicState           String?
  clinicPincode         String?
  latitude              Float
  longitude             Float
  consultationFee       Float
  averageRating         Float                     @default(0.0)
  totalReviews          Int                       @default(0)
  isVerified            Boolean                   @default(false)
  isAvailable           Boolean                   @default(true)
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  
  // Relations
  specializations       DoctorSpecialization[]
  reviews               DoctorReview[]
  appointments          Appointment[]
  recommendedSessions   RecommendedDoctor[]

  @@index([email])
  @@index([licenseNumber])
  @@index([clinicCity])
  @@map("doctors")
}

model Specialization {
  id                       String                    @id @default(cuid())
  name                     String                    @unique
  description              String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  
  // Relations
  doctors                  DoctorSpecialization[]
  conditions               SpecializationCondition[]

  @@index([name])
  @@map("specializations")
}

model DoctorSpecialization {
  id               String        @id @default(cuid())
  doctorId         String
  specializationId String
  isPrimary        Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  
  // Relations
  doctor           Doctor        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  specialization   Specialization @relation(fields: [specializationId], references: [id], onDelete: Cascade)

  @@unique([doctorId, specializationId])
  @@index([doctorId])
  @@index([specializationId])
  @@map("doctor_specializations")
}

model SpecializationCondition {
  id               String        @id @default(cuid())
  specializationId String
  conditionId      String
  relevanceScore   Float         @default(1.0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  
  // Relations
  specialization   Specialization @relation(fields: [specializationId], references: [id], onDelete: Cascade)
  condition        MedicalCondition @relation(fields: [conditionId], references: [id], onDelete: Cascade)

  @@unique([specializationId, conditionId])
  @@index([specializationId])
  @@index([conditionId])
  @@map("specialization_conditions")
}

model DoctorReview {
  id        String   @id @default(cuid())
  doctorId  String
  userId    String
  rating    Int      // 1-5 stars
  comment   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([userId])
  @@map("doctor_reviews")
}

model RecommendedDoctor {
  id             String         @id @default(cuid())
  sessionId      String
  doctorId       String
  symptoms       String[]
  matchScore     Float
  distance       Float?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  
  // Relations
  doctor         Doctor         @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  session        SymptomSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, doctorId])
  @@index([doctorId])
  @@index([sessionId])
  @@map("recommended_doctors")
}

// ============ APPOINTMENT MODELS ============

model Appointment {
  id            String         @id @default(cuid())
  status        String         @default("PENDING")
  userId        String
  doctorId      String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  // Relations
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctor        Doctor         @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  prescriptions Prescription[]

  @@index([userId])
  @@index([doctorId])
  @@map("appointments")
}

model Prescription {
  id            String      @id @default(cuid())
  medicine      String
  dosage        String
  instructions  String?
  appointmentId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  // Relations
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@map("prescriptions")
}

// ============ OTHER MODELS ============

model SymptomChecker {
  id        String   @id @default(cuid())
  userId    String
  input     String
  result    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("symptom_checkers")
}

model Diagnosis {
  id             String   @id @default(cuid())
  userId         String
  symptoms       String
  result         String
  confidence     Float?
  urgencyLevel   String?
  doctorType     String?
  aiExplanation  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  // Relations
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("diagnoses")
}
