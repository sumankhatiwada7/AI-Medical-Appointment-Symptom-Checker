// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model user {
  id              String           @id @default(uuid())
  name            String
  email           String           @unique
  password        String
  role            Role             @default(PATIENT)
  appointments    Appointment[]
  symptoms        Symptom[]
  symptomCheckers SymptomChecker[]
  diagnoses       Diagnosis[]
  latitude        Float?
  longitude       Float?

  symptomSessions SymptomSession[]

  refreshToken    String?
  createdat       DateTime         @default(now())
}

model Doctor {
  id                 String        @id @default(uuid())
  name               String
  email              String        @unique
  phone              String
  password           String
  qualifications     String
  licenseNumber      String        @unique
  yearsOfExperience  Int
  latitude           Float
  longitude          Float
  consultationFee    Float
  averageRating     Float    @default(0.0)
  totalReviews      Int      @default(0)
  doctorReviews     DoctorReview[]
  isVerified        Boolean  @default(false)
  isAvailable       Boolean  @default(true)
  recommendedSessions RecommendedDoctor[]
  appointments       Appointment[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}
model Specialization {
  id        String   @id @default(cuid())
  name      String   @unique
  description String?
  doctors   DoctorSpecialization[]
  conditions SpecializationCondition[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model DoctorSpecialization {
  id              String   @id @default(cuid())
  doctorId        String
  specializationId String
  isPrimary       Boolean  @default(false)
  doctor          Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  specialization  Specialization @relation(fields: [specializationId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@unique([doctorId, specializationId])
}
model SpecializationCondition {
  id              String   @id @default(cuid())
  specializationId String
  conditionId     String
  relevanceScore  Float    @default(1.0)
  specialization  Specialization @relation(fields: [specializationId], references: [id], onDelete: Cascade)
  condition       MedicalCondition @relation(fields: [conditionId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@unique([specializationId, conditionId])
}
model RecommendedDoctor {
  id              String   @id @default(cuid())
  sessionId       String   @unique
  doctorId        String
  symptoms        String[]
  matchScore      Float
  distance        Float?
  doctor          Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  symptomSession  SymptomSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SymptomSession {
  id                String   @id @default(cuid())
  userId            String
  symptoms          String[]
  age               Int
  gender            String
  duration          String?
  severity          String?
  predictedDisease  Json
  urgencyLevel      String
  aiExplanation     String   @db.Text
  recommendedDoctor String
  recommendedDoctors RecommendedDoctor[]  // Add this line
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

model Appointment {
  id        String   @id @default(uuid())
  status    String   @default("PENDING")

  userId    String
  user      user     @relation(fields: [userId], references: [id])
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id])

  prescription Prescription[]

  createdat DateTime @default(now())
}

model Symptom {
  id          String   @id @default(uuid())

  userId      String
  user        user @relation(fields: [userId], references: [id])

  name        String
  description String?

  severity    String?
  duration    String?

  createdat   DateTime @default(now())
}

model SymptomChecker {
  id        String   @id @default(uuid())
  userId    String
  user      user     @relation(fields: [userId], references: [id])
  input     String
  result    String
  createdat DateTime @default(now())
}

model Diagnosis {
  id             String   @id @default(cuid())

  symptoms       String
  result         String
  confidence     Float?

  urgencyLevel   String?
  doctorType     String?

  aiExplanation  String?

  userId         String
  user           user @relation(fields: [userId], references: [id])

  createdAt      DateTime @default(now())
}
model Prescription {
  id          String @id @default(cuid())
  medicine    String
  dosage      String
  instructions String?

  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id])

  createdAt   DateTime @default(now())
}
